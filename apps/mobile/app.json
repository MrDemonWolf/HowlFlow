{
  "expo": {
    "name": "HowlFlow",
    "slug": "howlflow",
    "owner": "mrdemonwolf-org",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "howlflow",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.mrdemonwolf.howlflow",
      "supportsTablet": true,
      "icon": "./assets/AppIcon.icon",
      "infoPlist": {
        "NSMotionUsageDescription": "HowlFlow uses haptic feedback for task completion and timer events."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0f1e"
      },
      "package": "com.mrdemonwolf.howlflow"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0a0f1e"
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "FILL_IN_AFTER_EAS_INIT"
      }
    }
  }
}
